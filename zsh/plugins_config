#!/bin/sh
#

# zsh syntax highlight
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern)
typeset -gA ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[single-quoted-argument]='fg=green'
ZSH_HIGHLIGHT_STYLES[bracket-level-1]='none'
ZSH_HIGHLIGHT_STYLES[bracket-level-2]='none'
ZSH_HIGHLIGHT_STYLES[bracket-level-3]='none'
ZSH_HIGHLIGHT_STYLES[double-quoted-argument]='fg=green'
ZSH_HIGHLIGHT_STYLES[dollar-double-quoted-argument]='fg=cyan'
ZSH_HIGHLIGHT_STYLES[comment]='fg=#7f848e,italic'
# pattern highlighter — matches unquoted $VAR and ${VAR}
# must use += syntax so the key is stored without literal quote characters
ZSH_HIGHLIGHT_PATTERNS+=('$[a-zA-Z_][a-zA-Z0-9_]#' 'fg=cyan')
ZSH_HIGHLIGHT_PATTERNS+=('${[^}]#}' 'fg=cyan')

# zsh-history-substring-search
zle -N history-substring-search-up
bindkey '^[OA' history-substring-search-up
zle -N history-substring-search-down
bindkey '^[OB' history-substring-search-down

HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_FOUND="bg=11,fg=black"
HISTORY_SUBSTRING_SEARCH_FUZZY="true"

# history search multi word
zstyle ":history-search-multi-word" highlight-color "bg=11,fg=black"
zstyle ":plugin:history-search-multi-word" active "bg=237,fg=255"
zstyle ":plugin:history-search-multi-word" check-paths "no"
# Wrap HSMW to fix a zsh 5.9 bug: it deletes zle-line-pre-redraw on entry and
# fails to restore it on exit, permanently breaking syntax highlighting and autosuggestions.
# Widget name must end in -word so HSMW's internal *-word pattern match triggers
# navigation correctly. Companion widgets follow the same naming convention.
_hsmw_fix-word() {
  zle history-search-multi-word "$@"
  if ! zle -la zle-line-pre-redraw 2>/dev/null && (( ${+functions[azhw:zle-line-pre-redraw]} )); then
    zle -N zle-line-pre-redraw azhw:zle-line-pre-redraw
  fi
}
zle -N _hsmw_fix-word
zle -N _hsmw_fix-word-backwards   history-search-multi-word
zle -N _hsmw_fix-word-pbackwards  history-search-multi-word
zle -N _hsmw_fix-word-pforwards   history-search-multi-word
bindkey "^R" _hsmw_fix-word

typeset -gA HSMW_HIGHLIGHT_STYLES
HSMW_HIGHLIGHT_STYLES[single-hyphen-option]="none"
HSMW_HIGHLIGHT_STYLES[double-hyphen-option]="none"
HSMW_HIGHLIGHT_STYLES[builtin]="fg=green"
HSMW_HIGHLIGHT_STYLES[single-quoted-argument]="fg=green"
HSMW_HIGHLIGHT_STYLES[double-quoted-argument]="fg=green"
HSMW_HIGHLIGHT_STYLES[variable]="fg=cyan"

# zsh-autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#7f848e'
ZSH_AUTOSUGGEST_STRATEGY=(history)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# Bind widgets at startup instead of letting _zsh_autosuggest_start run in precmd.
# Running _zsh_autosuggest_start inside precmd (which calls _zsh_autosuggest_bind_widgets
# and re-evals/re-registers hundreds of ZLE widgets) contributes to spurious blank lines.
_zsh_autosuggest_bind_widgets 2>/dev/null
precmd_functions=(${precmd_functions:#_zsh_autosuggest_start})

# Skip reset/fetch when keys are queued — keeps old suggestion visible during burst typing.
functions[_zsh_autosuggest_highlight_reset_orig]=$functions[_zsh_autosuggest_highlight_reset]
_zsh_autosuggest_highlight_reset() {
  (( KEYS_QUEUED_COUNT > 0 )) && return
  _zsh_autosuggest_highlight_reset_orig "$@"
}

functions[_zsh_autosuggest_fetch_orig]=$functions[_zsh_autosuggest_fetch]
_zsh_autosuggest_fetch() {
  (( KEYS_QUEUED_COUNT > 0 )) && return
  _zsh_autosuggest_fetch_orig "$@"
}

# Remove the intermediate POSTDISPLAY="" clear that causes the suggestion text
# to flash empty before the new suggestion is computed. Instead, run the original
# widget first with POSTDISPLAY untouched, then replace it atomically via fetch.
# Safe because history fetch is synchronous — no redraw happens between the widget
# call and the fetch, so the old suggestion is never shown in an inconsistent state.
_zsh_autosuggest_modify() {
  local -i retval
  local -i KEYS_QUEUED_COUNT
  local orig_buffer="$BUFFER"
  local orig_postdisplay="$POSTDISPLAY"

  _zsh_autosuggest_invoke_original_widget $@
  retval=$?

  emulate -L zsh

  if (( $PENDING > 0 || $KEYS_QUEUED_COUNT > 0 )); then
    return $retval
  fi

  if [[ "$BUFFER" = "$orig_buffer"* && "$orig_postdisplay" = "${BUFFER:$#orig_buffer}"* ]]; then
    POSTDISPLAY="${orig_postdisplay:$(($#BUFFER - $#orig_buffer))}"
    return $retval
  fi

  if (( ${+_ZSH_AUTOSUGGEST_DISABLED} )); then
    return $?
  fi

  if (( $#BUFFER > 0 )); then
    if [[ -z "$ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE" ]] || (( $#BUFFER <= $ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE )); then
      _zsh_autosuggest_fetch
    fi
  else
    POSTDISPLAY=
  fi

  return $retval
}

# _zsh_autosuggest_widget_clear wraps accept-line. Its `zle -R` call fires while
# ZLE is exiting accept-line and can produce an extra blank line on rapid Enter.
# ZLE redraws automatically after widgets, so the explicit -R is not needed.
_zsh_autosuggest_widget_clear() {
  local -i retval
  _zsh_autosuggest_highlight_reset
  _zsh_autosuggest_clear "$@"
  retval=$?
  _zsh_autosuggest_highlight_apply
  return $retval
}




