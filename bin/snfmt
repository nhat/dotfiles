#!/usr/bin/env bash
# Outputs formatted content, or the original unchanged if formatting fails.
set -uo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat >&2 <<'EOF'
usage: snfmt

Reads from stdin, auto-detects language, formats, and prints to stdout.
Best-effort: always outputs something, never breaks a pipe.

  snfmt '{"a":1}'                 format argument directly
  echo '{"a":1}' | snfmt          format stdin
  cat file.json  | snfmt          format a file
  pbpaste        | snfmt | pbcopy format clipboard in place

Supported languages: json, xml, java, lua, javascript, yaml
Unknown formats: strips trailing whitespace and dedents
EOF
  exit 0
fi

if [[ -n "${1:-}" ]]; then
  content="$1"
elif [[ -t 0 ]]; then
  "$0" --help
  exit 1
else
  content=$(cat)
fi

[[ -z "${content:-}" ]] && exit 0

tmp=$(mktemp "${TMPDIR:-/tmp}/snfmt.XXXXXX")
trap 'rm -f "$tmp"' EXIT
printf '%s\n' "$content" > "$tmp"

if grep -qE '^\s*[\{\[]' <<< "$content"; then
  ext="json"
elif grep -qE '^\s*<' <<< "$content"; then
  ext="xml"
elif grep -qE '(public class |import java\.|package [a-z])' <<< "$content"; then
  ext="java"
elif grep -qE '(^function |^local |^end$)' <<< "$content"; then
  ext="lua"
elif grep -qE '(const |let |var |=>|require\()' <<< "$content"; then
  ext="javascript"
elif grep -qE '^(---|[a-z_]+:)' <<< "$content"; then
  ext="yaml"
else
  ext="txt"
fi

if [[ "$ext" == "txt" ]]; then
  python3 -c "
import sys, textwrap
lines = sys.stdin.read().splitlines()
lines = [l.rstrip() for l in lines]
while lines and not lines[0].strip(): lines.pop(0)
while lines and not lines[-1].strip(): lines.pop()
print(textwrap.dedent('\n'.join(lines)))
" < "$tmp"
else
  nvim --headless "$tmp" -c "set ft=$ext" -c 'Neoformat' -c 'wq!' 2>/dev/null || true  # cat below outputs original on failure
  cat "$tmp"
fi

echo "Detected: $ext" >&2
